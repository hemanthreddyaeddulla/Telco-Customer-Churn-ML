venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.vscode/
.gradio/
.coverage
htmlcov/
mlruns/
mlartifacts/
*.db
logs/
notebooks/
data/raw/
data/processed/
tests/
